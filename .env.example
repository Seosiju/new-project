# App
APP_ENV=development
APP_NAME=new-project
WEB_PORT=3000
API_PORT=8000

# Local services from docker-compose.yml
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
DATABASE_URL=postgresql://app:app@localhost:5433/new_project
REDIS_URL=redis://localhost:6379/0

# AI provider keys - copy to .env and fill only what you use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Auth placeholder for later
AUTH_SECRET=
